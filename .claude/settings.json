{
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(sudo *)",
      "Bash(doas *)",
      "Bash(su *)",
      "Bash(brew *)",
      "Bash(apt *)",
      "Bash(apt-get *)",
      "Bash(yum *)",
      "Bash(dnf *)",
      "Bash(pacman *)",
      "Bash(zypper *)",
      "Bash(nix-*)",
      "Bash(systemctl *)",
      "Bash(service *)",
      "Bash(launchctl *)",
      "Bash(pmset *)",
      "Bash(defaults write *)",
      "Bash(spctl *)",
      "Bash(csrutil *)",
      "Bash(diskutil *)",
      "Bash(fdisk *)",
      "Bash(mkfs *)",
      "Bash(mount *)",
      "Bash(umount *)",
      "Bash(reboot *)",
      "Bash(shutdown *)",
      "Bash(poweroff *)",
      "Bash(useradd *)",
      "Bash(usermod *)",
      "Bash(userdel *)",
      "Bash(passwd *)",
      "Bash(chsh *)",
      "Edit(//etc/**)",
      "Edit(//usr/**)",
      "Edit(//bin/**)",
      "Edit(//sbin/**)",
      "Edit(//System/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.kube/**)",
      "Edit(~/.config/**)",
      "Write(//etc/**)",
      "Write(//usr/**)",
      "Write(//bin/**)",
      "Write(//sbin/**)",
      "Write(//System/**)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gnupg/**)",
      "Write(~/.kube/**)",
      "Write(~/.config/**)"
    ],
    "ask": [
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git revert *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(git cherry-pick *)",
      "Bash(git clean *)",
      "Bash(git checkout -- *)",
      "Bash(git branch -D *)",
      "Bash(git push --force*)",
      "Bash(gh pr *)",
      "Read(//**)",
      "Read(~/**)",
      "Read(../**)",
      "Edit(//**)",
      "Edit(~/**)",
      "Edit(../**)",
      "Write(//**)",
      "Write(~/**)",
      "Write(../**)"
    ],
    "allow": [
      "Read(/**)",
      "Edit(/**)",
      "Write(/**)",
      "Bash(git *)",
      "Bash(gh *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": false,
    "failIfUnavailable": false,
    "filesystem": {
      "denyWrite": [
        "/etc",
        "/usr",
        "/bin",
        "/sbin",
        "/System",
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.kube",
        "~/.config"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.kube"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json, os, re, sys\ndata=json.load(sys.stdin)\ntool=data.get('tool_name','')\ninp=data.get('tool_input',{}) or {}\ndef walk(v):\n    if isinstance(v, dict):\n        for x in v.values(): yield from walk(x)\n    elif isinstance(v, list):\n        for x in v: yield from walk(x)\n    elif isinstance(v, str):\n        yield v\nvalues=list(walk(inp))\noutside=False\nfor v in values:\n    if re.search(r'(^|[\\s\\\"\\'])((\\.\\./)|~/|/)', v):\n        outside=True\n        break\nif outside:\n    print(json.dumps({\n        'hookSpecificOutput': {\n            'hookEventName': 'PreToolUse',\n            'permissionDecision': 'ask',\n            'permissionDecisionReason': 'Access outside the project root requires manual approval.'\n        }\n    }))\" "
          }
        ]
      }
    ]
  }
}
